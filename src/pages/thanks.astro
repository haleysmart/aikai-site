---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="AIkai - It starts and ends with AI. Building intelligent solutions for tomorrow." />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>Message Sent - AIkai</title>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-logo" aria-label="AIkai home">
        <img src="/logo-nav.png" alt="AIkai" />
        <span class="nav-logo-text">It starts and ends with AI.</span>
      </a>
      <ul class="nav-links">
        <li><a href="/#about">About</a></li>
        <li><a href="/#products">Products</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
    </nav>
    <section class="hero" style="padding: 6rem 2rem;">
      <div class="hero-header">
        <img src="/logo.png" alt="AIkai" class="hero-logo" />
      </div>
      <h1>Message Sent.</h1>
      <p class="hero-desc">
        Thanks for reaching out. We'll be in touch soon.
      </p>
      <div class="hero-cta">
        <a href="/" class="btn btn-outline">Back to Home</a>
      </div>
    </section>
  </body>
</html>
